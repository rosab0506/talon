# Talon Infrastructure Configuration (talon.config.yaml)
# Owner: DevOps / platform team
#
# This file controls HOW Talon runs: LLM provider connections, gateway settings,
# storage paths, encryption keys, and observability. It does NOT define agent
# behaviour — for that, see agent.talon.yaml (owned by governance/compliance).

# LLM: provider registry and cost estimation (pricing table path)
llm:
  pricing_file: "pricing/models.yaml"

# Legacy: single provider (openai, anthropic, bedrock, ollama)
llm_provider: openai

# Logging
log_level: info
log_format: console

# Evidence storage
evidence:
  type: sqlite
  path: ~/.talon/evidence.db

# Governed semantic cache (optional, off by default — set enabled: true to reduce LLM cost for similar prompts)
cache:
  enabled: false
  default_ttl: 3600
  similarity_threshold: 0.92
  max_entries_per_tenant: 10000

# Secrets encryption key (generate with: openssl rand -hex 32)
# Set via environment: export TALON_SECRETS_KEY=<key>
secrets_key_env: TALON_SECRETS_KEY

# Multi-tenant configuration (optional)
tenants:
  - id: default
    display_name: Default Tenant
    budgets:
      daily: 200.0
      monthly: 3000.0
    rate_limit: 30
