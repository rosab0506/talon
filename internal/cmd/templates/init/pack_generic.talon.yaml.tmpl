# Talon Agent Policy -- Generic Starter Pack (agent.talon.yaml)
# Generated by: talon init --pack generic
# Date: {{ .Date }}

agent:
  name: {{ .Name }}
  description: Generic AI agent with policy enforcement
  version: 1.0.0
  model_tier: 1

capabilities:
  # Keep this list short; add tools intentionally.
  allowed_tools:
    - file_read
    - web_search
  forbidden_patterns:
    - ".env"
    - "secrets"
    - "credentials"

policies:
  # Start with conservative budgets and raise after observing real usage.
  cost_limits:
    per_request: 2.0
    daily: 50.0
    monthly: 500.0
  resource_limits:
    timeout:
      operation: "60s"
      tool_execution: "5m"
      agent_total: "30m"
  rate_limits:
    requests_per_minute: 30
    concurrent_executions: 1
  data_classification:
    input_scan: true
    output_scan: true
    redact_pii: true   # or use redact_input/redact_output for granular control
  model_routing:
    tier_0:
      primary: gpt-4o-mini
      location: any
    tier_1:
      primary: gpt-4o
      fallback: gpt-4o-mini
      location: eu
    tier_2:
      primary: gpt-4o
      location: eu
      bedrock_only: true

audit:
  log_level: detailed
  retention_days: 365
  include_prompts: false
  include_responses: false
  # include_original_prompts: false  # When true + redact_input, also stores pre-redaction prompt (forensic opt-in; see ADR-002)

compliance:
  frameworks: [gdpr, eu-ai-act]
  data_residency: eu
  ai_act_risk_level: limited
  human_oversight: on-demand

metadata:
  department: engineering
  owner: "{{ .Owner }}"
  tags: [ai-agent, generic, governed]
