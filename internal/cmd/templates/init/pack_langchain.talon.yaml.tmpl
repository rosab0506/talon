# Talon Agent Policy -- LangChain Starter Pack (agent.talon.yaml)
# Generated by: talon init --pack langchain
# Date: {{ .Date }}

agent:
  name: {{ .Name }}
  description: LangChain agent with policy governance
  version: 1.0.0
  model_tier: 1

capabilities:
  allowed_tools:
    - web_search
    - calculator
    - sql_database_query
    - file_read
  forbidden_patterns:
    - DELETE FROM
    - DROP TABLE
    - rm -rf
    - os.system
    - subprocess.run

policies:
  cost_limits:
    per_request: 2.0
    daily: 10.0
    monthly: 200.0
  resource_limits:
    timeout:
      operation: "60s"
      tool_execution: "5m"
      agent_total: "30m"
  rate_limits:
    requests_per_minute: 30
    concurrent_executions: 2
  data_classification:
    input_scan: true
    output_scan: true
    redact_pii: true
  model_routing:
    tier_0:
      primary: gpt-4o-mini
      location: eu
    tier_1:
      primary: gpt-4o
      fallback: gpt-4o-mini
      location: eu
    tier_2:
      primary: gpt-4o
      location: eu
      bedrock_only: true

audit:
  log_level: detailed
  retention_days: 365
  include_prompts: false
  include_responses: false

compliance:
  frameworks: [gdpr]
  data_residency: eu
  ai_act_risk_level: limited

metadata:
  department: engineering
  owner: "{{ .Owner }}"
  tags: [ai-agent, langchain, governed]
