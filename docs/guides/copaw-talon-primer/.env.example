# Required: your real OpenAI (or other provider) API key. Talon stores it and uses it when
# forwarding requests from CoPaw; CoPaw never sees this key.
OPENAI_API_KEY=

# Optional: host port (default 8080).
# TALON_PORT=8080

# Optional: for production, set explicit crypto keys.
# TALON_SECRETS_KEY=  # 64 hex chars
# TALON_SIGNING_KEY=  # 64+ hex chars
